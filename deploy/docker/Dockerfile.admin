FROM node:20-alpine AS builder

WORKDIR /app

# 安裝依賴
COPY admin/dllm-admin/package*.json ./
RUN npm ci

# 複製原始碼
COPY admin/dllm-admin/ .

# 建構
RUN npm run build

# 執行階段
FROM nginx:alpine

# 複製建構結果
COPY --from=builder /app/dist /usr/share/nginx/html

# 複製 nginx 配置
COPY admin/dllm-admin/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
