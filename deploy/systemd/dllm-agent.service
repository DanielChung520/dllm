[Unit]
Description=dllm Agent Service
After=dllm-core.service
Requires=dllm-core.service

[Service]
Type=simple
User=dllm
Group=dllm
WorkingDirectory=/opt/dllm/services/dllm-agent

Environment="DLLM_CORE_URL=http://localhost:11400"

ExecStart=/opt/dllm/services/dllm-agent/venv/bin/python -m uvicorn src.main:app --host 0.0.0.0 --port 8002

Restart=always
RestartSec=10

StandardOutput=journal
StandardError=journal
SyslogIdentifier=dllm-agent

[Install]
WantedBy=multi-user.target
